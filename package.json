{
  "name": "bitcoin-ofac-addresses",
  "version": "1.0.3",
  "description": "OFAC sanctioned Bitcoin addresses, synced daily from the official U.S. Treasury OFAC sanctions list. Zero dependencies.",
  "keywords": [
    "bitcoin",
    "ofac",
    "sanctions",
    "compliance",
    "crypto",
    "btc",
    "treasury",
    "aml",
    "kyc"
  ],
  "author": "Nick (https://github.com/nhamilton1)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nhamilton1/bitcoin-ofac-addresses.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./static": {
      "types": "./dist/static.d.ts",
      "bun": "./src/static.ts",
      "default": "./dist/static.js"
    },
    "./addresses.json": "./src/data/addresses.json"
  },
  "files": [
    "src",
    "dist",
    "!src/**/*.test.ts"
  ],
  "scripts": {
    "update": "bun run script/update-addresses.ts",
    "build": "bun build ./src/index.ts ./src/static.ts --outdir dist --target node && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "1.3.0",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "typescript": "^5 || ^6"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
